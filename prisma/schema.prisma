generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ConditionGrade {
  CONCOURS
  EXCELLENT
  VERY_GOOD
  GOOD
  FAIR
}

enum FeedbackRating {
  POSITIVE
  NEGATIVE
}

enum CollectorTier {
  NEW
  VERIFIED
  ELITE
  APEX
}

enum ReputationEventType {
  PAYMENT_VERIFIED
  DELIVERY_CONFIRMED
  PURCHASE_COMPLETED
  SALE_COMPLETED
  POSITIVE_FEEDBACK
  NEGATIVE_FEEDBACK
  CONDITION_REPORT_QUALITY
  DISPUTE_OPENED
  DISPUTE_LOST
  CHARGEBACK
  SELLER_CANCELLATION_AFTER_BID
  BUYER_NONPAYMENT
  POLICY_VIOLATION
  SOCIAL_HELPFUL_UPVOTE
  SOCIAL_SPAM_FLAG
}

enum MarketingTrafficEventType {
  VIEW
  SHARE_CLICK
  BID_CLICK
  EXTERNAL_REFERRAL
}

enum MarketingTrafficSource {
  DIRECT
  INSTAGRAM
  FACEBOOK
  LINKEDIN
  TIKTOK
  EMAIL
  CARMUNITY
  UNKNOWN
}

enum MarketingCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

/// Discussion reactions (threads & replies). Distinct from feed Post [Like].
enum DiscussionReactionKind {
  LIKE
  FIRE
  WRENCH
  MIND_BLOWN
  LAUGH
  RESPECT
}

enum DiscussionReportReason {
  harassment
  spam
  hate
  illegal
  self_harm
  explicit
  misinformation
  off_topic
  other
}

enum DiscussionReportStatus {
  OPEN
  REVIEWING
  ACTIONED
  DISMISSED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?
  handle       String    @unique
  name         String?
  bio          String?
  avatarUrl    String?
  location     String?
  image        String?
  emailVerified DateTime?
  acceptedTermsAt DateTime?
  acceptedPrivacyAt DateTime?
  acceptedCommunityGuidelinesAt DateTime?
  /// Seeded Carmunity demo profile — safe to delete in bulk; see CARMUNITY_DISCUSSIONS_DEMO_CONTENT.md
  isDemoSeed   Boolean   @default(false)
  role         Role      @default(USER)
  instagramUrl String?
  facebookUrl  String?
  twitterUrl   String?
  tiktokUrl    String?
  accounts     Account[]
  sessions     Session[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  followers    Follow[]  @relation("Following")
  following    Follow[]  @relation("Follower")
  posts        Post[]
  likes        Like[]
  comments     Comment[]
  garageCars   GarageCar[]
  auctions     Auction[]  @relation("Seller")
  purchasedAuctions Auction[] @relation("Buyer")
  bids         Bid[]
  autoBids     AutoBid[]
  notifications Notification[]
  reputationEvents ReputationEvent[]
  feedbackGiven   AuctionFeedback[] @relation("FeedbackFrom")
  feedbackReceived AuctionFeedback[] @relation("FeedbackTo")

  reputationScore       Int           @default(0)
  collectorTier         CollectorTier @default(NEW)
  reputationUpdatedAt   DateTime?
  completedSalesCount   Int           @default(0)
  completedPurchasesCount Int         @default(0)
  disputesLostCount     Int           @default(0)
  uniqueCounterpartyCount Int         @default(0)
  weeklyMarketingDigestOptIn Boolean @default(false)
  lastMarketingDigestSentAt DateTime?

  trafficEventsAsViewer TrafficEvent[]
  marketingCampaigns    Campaign[]
  marketingPresets      MarketingPreset[]

  forumThreads ForumThread[]
  forumReplies ForumReply[]
  forumThreadReactions ForumThreadReaction[]
  forumReplyReactions ForumReplyReaction[]
  userBadges UserBadge[]
  auctionWatches AuctionWatch[]
  /// Outbound Carmunity / system notifications where this user is the actor.
  notificationsSent Notification[] @relation("NotificationActor")
  discussionReportsSubmitted DiscussionReport[] @relation("DiscussionReportReporter")
  discussionReportsReviewed DiscussionReport[] @relation("DiscussionReportReviewer")

  forumThreadsHidden ForumThread[] @relation("ForumThreadHiddenBy")
  forumRepliesHidden ForumReply[] @relation("ForumReplyHiddenBy")
  blocksGiven          UserBlock[] @relation("UserBlockBlocker")
  blocksReceived       UserBlock[] @relation("UserBlockBlocked")
  mutesGiven           UserMute[]  @relation("UserMuteMuter")
  mutesReceived        UserMute[]  @relation("UserMuteMuted")
  forumThreadSubscriptions ForumThreadSubscription[]
}

/// Top-level Carmunity forum area (e.g. Mechanics Corner, Gear Interests). Distinct from feed [Post].
model ForumSpace {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?  @db.Text
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories ForumCategory[]

  @@index([isActive, sortOrder])
}

/// Category within a space (thread bucket). Slugs are unique per space.
model ForumCategory {
  id          String   @id @default(cuid())
  spaceId     String
  slug        String
  title       String
  description String?  @db.Text
  sortOrder   Int      @default(0)
  /// Optional structured tags (e.g. make/model) — evolve without schema churn.
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  space   ForumSpace    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  threads ForumThread[]

  @@unique([spaceId, slug])
  @@index([spaceId, sortOrder])
}

/// Discussion thread — title + body; not a [Post] (no feed like/auction promo semantics).
model ForumThread {
  id             String   @id @default(cuid())
  categoryId     String
  authorId       String
  title          String
  body           String   @db.Text
  replyCount     Int      @default(0)
  lastActivityAt DateTime @default(now())
  locked         Boolean  @default(false)
  /// Seeded demo thread — see CARMUNITY_DISCUSSIONS_DEMO_CONTENT.md
  isDemoSeed     Boolean  @default(false)
  /// Soft moderation hide — record kept; non-admins do not see in lists or thread view.
  isHidden       Boolean  @default(false)
  hiddenAt       DateTime?
  hiddenById     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  author   User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  hiddenBy User?         @relation("ForumThreadHiddenBy", fields: [hiddenById], references: [id], onDelete: SetNull)
  replies  ForumReply[]
  threadReactions ForumThreadReaction[]
  discussionReports DiscussionReport[]
  subscriptions ForumThreadSubscription[]

  @@index([categoryId, lastActivityAt])
  @@index([authorId])
}

/// User saved / followed a thread for retention (Phase I). Distinct from auction watchlist.
model ForumThreadSubscription {
  id        String   @id @default(cuid())
  userId    String
  threadId  String
  createdAt DateTime @default(now())
  /// Last time the subscriber opened the thread (Phase J); used for lightweight “new activity” on saves.
  lastViewedAt DateTime?

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([userId, threadId])
  @@index([userId])
  @@index([threadId])
}

model ForumReply {
  id        String   @id @default(cuid())
  threadId  String
  authorId  String
  /// When set, this reply is nested under another reply in the same thread (Phase F).
  parentReplyId String?
  body      String   @db.Text
  /// Seeded demo reply — see CARMUNITY_DISCUSSIONS_DEMO_CONTENT.md
  isDemoSeed Boolean  @default(false)
  isHidden   Boolean  @default(false)
  hiddenAt   DateTime?
  hiddenById String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  hiddenBy User?    @relation("ForumReplyHiddenBy", fields: [hiddenById], references: [id], onDelete: SetNull)
  parentReply ForumReply?  @relation("ForumReplyThread", fields: [parentReplyId], references: [id], onDelete: SetNull)
  childReplies ForumReply[] @relation("ForumReplyThread")
  replyReactions ForumReplyReaction[]
  discussionReports DiscussionReport[]

  @@index([threadId, createdAt])
  @@index([authorId])
  @@index([parentReplyId])
}

/// User-submitted moderation signal for Discussions (Phase G). Not a verdict.
model DiscussionReport {
  id           String                 @id @default(cuid())
  reporterId   String
  threadId     String?
  replyId      String?
  reason       DiscussionReportReason
  details      String?                @db.Text
  status       DiscussionReportStatus @default(OPEN)
  moderatorNote String?             @db.Text
  createdAt    DateTime               @default(now())
  reviewedAt   DateTime?
  reviewedById String?

  reporter   User         @relation("DiscussionReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  thread     ForumThread? @relation(fields: [threadId], references: [id], onDelete: Cascade)
  reply      ForumReply?  @relation(fields: [replyId], references: [id], onDelete: Cascade)
  reviewedBy User?        @relation("DiscussionReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([reporterId])
  @@index([threadId])
  @@index([replyId])
}

/// User A blocks user B — B’s discussions content is hidden from A only (Phase H).
model UserBlock {
  id         String   @id @default(cuid())
  blockerId  String
  blockedId  String
  createdAt  DateTime @default(now())

  blocker User @relation("UserBlockBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("UserBlockBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

/// Muting reduces notification noise from a user; they may still appear in threads (Phase H).
model UserMute {
  id           String   @id @default(cuid())
  userId       String
  mutedUserId  String
  createdAt    DateTime @default(now())

  muter User @relation("UserMuteMuter", fields: [userId], references: [id], onDelete: Cascade)
  muted User @relation("UserMuteMuted", fields: [mutedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, mutedUserId])
  @@index([userId])
  @@index([mutedUserId])
}

model ForumThreadReaction {
  id        String                 @id @default(cuid())
  threadId String
  userId    String
  kind      DiscussionReactionKind
  createdAt DateTime               @default(now())
  updatedAt DateTime               @default(now()) @updatedAt

  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// One reaction per user per thread (kind can change).
  @@unique([threadId, userId])
  @@index([threadId])
  @@index([userId])
}

model ForumReplyReaction {
  id        String                 @id @default(cuid())
  replyId   String
  userId    String
  kind      DiscussionReactionKind
  createdAt DateTime               @default(now())
  updatedAt DateTime               @default(now()) @updatedAt

  reply ForumReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// One reaction per user per reply (kind can change).
  @@unique([replyId, userId])
  @@index([replyId])
  @@index([userId])
}

/// Platform-defined badge (e.g. Top Contributor). Awarded via UserBadge.
model Badge {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?  @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userBadges UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

/// Seller-saved Share & Promote defaults (UTM campaign + copy options). Manual only.
model MarketingPreset {
  id              String   @id @default(cuid())
  userId          String
  name            String
  source          String
  medium          String
  campaignLabel   String?
  copyVariant     String
  includeHashtags Boolean  @default(true)
  includeKeywords Boolean  @default(true)
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDefault])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token     String?
  expires_at       Int?
  token_type       String?
  scope            String?
  id_token         String?
  session_state    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Post {
  id        String   @id @default(cuid())
  authorId  String
  /// Optional listing promoted via seller marketing → Carmunity (nullable for ordinary posts).
  auctionId String?
  content   String?
  imageUrl  String?
  createdAt DateTime @default(now())

  author  User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  auction Auction? @relation("AuctionPromoPosts", fields: [auctionId], references: [id], onDelete: SetNull)
  likes   Like[]
  comments Comment[]

  @@index([authorId])
  @@index([createdAt])
  @@index([auctionId])
}

model Like {
  userId String
  postId String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
}

model GarageCar {
  id        String   @id @default(cuid())
  ownerId   String
  type      String   // GARAGE | DREAM
  year      Int
  make      String
  model     String
  trim      String?
  notes     String?
  createdAt DateTime @default(now())

  owner  User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  images GarageCarImage[]

  @@index([ownerId])
  @@index([ownerId, type])
}

model GarageCarImage {
  id          String   @id @default(cuid())
  garageCarId String
  url         String
  sortOrder   Int      @default(0)

  garageCar GarageCar @relation(fields: [garageCarId], references: [id], onDelete: Cascade)

  @@index([garageCarId])
}

model Auction {
  id                String    @id @default(cuid())
  sellerId          String
  buyerId           String?
  title             String
  description       String?
  year              Int
  make              String
  model             String
  trim              String?
  vin               String?
  mileage           Int?
  reservePriceCents Int?
  buyNowPriceCents  Int?
  buyNowExpiresAt   DateTime?
  startAt           DateTime
  endAt             DateTime
  status            String    // DRAFT | LIVE | SOLD | ENDED
  conditionGrade    ConditionGrade?
  conditionSummary  String?   @db.Text
  imperfections     Json?
  latitude          Float?
  longitude         Float?
  locationZip       String?
  createdAt         DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  seller  User          @relation("Seller", fields: [sellerId], references: [id], onDelete: Cascade)
  buyer   User?         @relation("Buyer", fields: [buyerId], references: [id], onDelete: SetNull)
  images  AuctionImage[]
  damageImages AuctionDamageImage[]
  bids    Bid[]
  autoBids AutoBid[]
  feedbacks AuctionFeedback[]
  trafficEvents      TrafficEvent[]
  marketingCampaigns Campaign[]
  auctionAnalytics   AuctionAnalytics[]
  promoPosts         Post[]           @relation("AuctionPromoPosts")
  watches            AuctionWatch[]

  @@index([sellerId])
  @@index([buyerId])
  @@index([status])
  @@index([endAt])
  @@index([make, model, year])
  @@index([status, endAt])
  @@index([status, createdAt])
  @@index([latitude, longitude])
}

model AuctionImage {
  id        String   @id @default(cuid())
  auctionId String
  url       String
  sortOrder Int      @default(0)

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@index([auctionId])
}

/// User-saved auction for Carmunity watchlist (not bids, not garage inventory).
model AuctionWatch {
  id        String   @id @default(cuid())
  userId    String
  auctionId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@unique([userId, auctionId])
  @@index([userId])
  @@index([auctionId])
}

model AuctionDamageImage {
  id        String   @id @default(cuid())
  auctionId String
  label     String
  imageUrl  String
  createdAt DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@index([auctionId])
}

model AuctionFeedback {
  id         String         @id @default(cuid())
  auctionId  String
  fromUserId String
  toUserId   String
  rating     FeedbackRating
  note       String?        @db.VarChar(500)
  createdAt  DateTime       @default(now())

  auction  Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  fromUser User    @relation("FeedbackFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User    @relation("FeedbackTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([auctionId, fromUserId])
  @@index([toUserId])
  @@index([auctionId])
}

model Bid {
  id        String   @id @default(cuid())
  auctionId String
  bidderId  String
  amountCents Int
  createdAt DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidder User     @relation(fields: [bidderId], references: [id], onDelete: Cascade)

  @@index([auctionId])
  @@index([bidderId])
}

model AutoBid {
  id            String   @id @default(cuid())
  auctionId     String
  bidderId      String
  maxAmountCents Int
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidder User     @relation(fields: [bidderId], references: [id], onDelete: Cascade)

  @@unique([auctionId, bidderId])
  @@index([auctionId])
}

model Notification {
  id         String    @id @default(cuid())
  userId     String
  /// User who triggered this notification (discussions / social), when applicable.
  actorId    String?
  /// Focal entity id for dedupe (e.g. thread id, reply id). Optional for legacy rows.
  targetId   String?
  type       String
  payloadJson String
  createdAt  DateTime  @default(now())
  readAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, readAt])
  @@index([userId, type, actorId, targetId, createdAt])
}

model ReputationEvent {
  id         String             @id @default(cuid())
  userId     String
  type       ReputationEventType
  points     Int
  basePoints Int
  meta       Json?
  createdAt  DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, type])
}

model TrafficEvent {
  id        String                  @id @default(cuid())
  auctionId String
  userId    String?
  eventType MarketingTrafficEventType
  source    MarketingTrafficSource  @default(UNKNOWN)
  metadata  Json?
  createdAt DateTime                @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([auctionId])
  @@index([auctionId, createdAt])
  @@index([userId])
}

/// Daily rollups for VIEW / SHARE_CLICK only (UTC calendar day). Rebuilt via backfill; incremented on ingest.
model AuctionAnalytics {
  id          String    @id @default(cuid())
  auctionId   String
  day         DateTime  @db.Date
  views       Int       @default(0)
  shareClicks Int       @default(0)
  lastEventAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@unique([auctionId, day])
  @@index([auctionId])
}

model Campaign {
  id        String                  @id @default(cuid())
  auctionId String
  userId    String
  name      String
  type      String
  status    MarketingCampaignStatus   @default(DRAFT)
  startAt   DateTime?
  endAt     DateTime?
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  auction Auction         @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  events  CampaignEvent[]

  @@index([userId])
  @@index([auctionId])
  @@index([userId, status])
}

model CampaignEvent {
  id         String   @id @default(cuid())
  campaignId String
  eventType  String
  metadata   Json?
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([campaignId, createdAt])
}
