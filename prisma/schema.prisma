generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ConditionGrade {
  CONCOURS
  EXCELLENT
  VERY_GOOD
  GOOD
  FAIR
}

enum FeedbackRating {
  POSITIVE
  NEGATIVE
}

enum CollectorTier {
  NEW
  VERIFIED
  ELITE
  APEX
}

enum ReputationEventType {
  PAYMENT_VERIFIED
  DELIVERY_CONFIRMED
  PURCHASE_COMPLETED
  SALE_COMPLETED
  POSITIVE_FEEDBACK
  NEGATIVE_FEEDBACK
  CONDITION_REPORT_QUALITY
  DISPUTE_OPENED
  DISPUTE_LOST
  CHARGEBACK
  SELLER_CANCELLATION_AFTER_BID
  BUYER_NONPAYMENT
  POLICY_VIOLATION
  SOCIAL_HELPFUL_UPVOTE
  SOCIAL_SPAM_FLAG
}

enum MarketingTrafficEventType {
  VIEW
  SHARE_CLICK
  BID_CLICK
  EXTERNAL_REFERRAL
}

enum MarketingTrafficSource {
  DIRECT
  INSTAGRAM
  FACEBOOK
  LINKEDIN
  TIKTOK
  EMAIL
  CARMUNITY
  UNKNOWN
}

enum MarketingCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?
  handle       String    @unique
  name         String?
  bio          String?
  avatarUrl    String?
  location     String?
  image        String?
  emailVerified DateTime?
  role         Role      @default(USER)
  instagramUrl String?
  facebookUrl  String?
  twitterUrl   String?
  tiktokUrl    String?
  accounts     Account[]
  sessions     Session[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  followers    Follow[]  @relation("Following")
  following    Follow[]  @relation("Follower")
  posts        Post[]
  likes        Like[]
  comments     Comment[]
  garageCars   GarageCar[]
  auctions     Auction[]  @relation("Seller")
  purchasedAuctions Auction[] @relation("Buyer")
  bids         Bid[]
  autoBids     AutoBid[]
  notifications Notification[]
  reputationEvents ReputationEvent[]
  feedbackGiven   AuctionFeedback[] @relation("FeedbackFrom")
  feedbackReceived AuctionFeedback[] @relation("FeedbackTo")

  reputationScore       Int           @default(0)
  collectorTier         CollectorTier @default(NEW)
  reputationUpdatedAt   DateTime?
  completedSalesCount   Int           @default(0)
  completedPurchasesCount Int         @default(0)
  disputesLostCount     Int           @default(0)
  uniqueCounterpartyCount Int         @default(0)
  weeklyMarketingDigestOptIn Boolean @default(false)
  lastMarketingDigestSentAt DateTime?

  trafficEventsAsViewer TrafficEvent[]
  marketingCampaigns    Campaign[]
  marketingPresets      MarketingPreset[]

  forumThreads ForumThread[]
  forumReplies ForumReply[]
}

/// Top-level Carmunity forum area (e.g. Mechanics Corner, Gear Interests). Distinct from feed [Post].
model ForumSpace {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?  @db.Text
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories ForumCategory[]

  @@index([isActive, sortOrder])
}

/// Category within a space (thread bucket). Slugs are unique per space.
model ForumCategory {
  id          String   @id @default(cuid())
  spaceId     String
  slug        String
  title       String
  description String?  @db.Text
  sortOrder   Int      @default(0)
  /// Optional structured tags (e.g. make/model) — evolve without schema churn.
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  space   ForumSpace    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  threads ForumThread[]

  @@unique([spaceId, slug])
  @@index([spaceId, sortOrder])
}

/// Discussion thread — title + body; not a [Post] (no feed like/auction promo semantics).
model ForumThread {
  id             String   @id @default(cuid())
  categoryId     String
  authorId       String
  title          String
  body           String   @db.Text
  replyCount     Int      @default(0)
  lastActivityAt DateTime @default(now())
  locked         Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  author   User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  replies  ForumReply[]

  @@index([categoryId, lastActivityAt])
  @@index([authorId])
}

model ForumReply {
  id        String   @id @default(cuid())
  threadId  String
  authorId  String
  body      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([authorId])
}

/// Seller-saved Share & Promote defaults (UTM campaign + copy options). Manual only.
model MarketingPreset {
  id              String   @id @default(cuid())
  userId          String
  name            String
  source          String
  medium          String
  campaignLabel   String?
  copyVariant     String
  includeHashtags Boolean  @default(true)
  includeKeywords Boolean  @default(true)
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDefault])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token     String?
  expires_at       Int?
  token_type       String?
  scope            String?
  id_token         String?
  session_state    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Post {
  id        String   @id @default(cuid())
  authorId  String
  /// Optional listing promoted via seller marketing → Carmunity (nullable for ordinary posts).
  auctionId String?
  content   String?
  imageUrl  String?
  createdAt DateTime @default(now())

  author  User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  auction Auction? @relation("AuctionPromoPosts", fields: [auctionId], references: [id], onDelete: SetNull)
  likes   Like[]
  comments Comment[]

  @@index([authorId])
  @@index([createdAt])
  @@index([auctionId])
}

model Like {
  userId String
  postId String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
}

model GarageCar {
  id        String   @id @default(cuid())
  ownerId   String
  type      String   // GARAGE | DREAM
  year      Int
  make      String
  model     String
  trim      String?
  notes     String?
  createdAt DateTime @default(now())

  owner  User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  images GarageCarImage[]

  @@index([ownerId])
  @@index([ownerId, type])
}

model GarageCarImage {
  id          String   @id @default(cuid())
  garageCarId String
  url         String
  sortOrder   Int      @default(0)

  garageCar GarageCar @relation(fields: [garageCarId], references: [id], onDelete: Cascade)

  @@index([garageCarId])
}

model Auction {
  id                String    @id @default(cuid())
  sellerId          String
  buyerId           String?
  title             String
  description       String?
  year              Int
  make              String
  model             String
  trim              String?
  vin               String?
  mileage           Int?
  reservePriceCents Int?
  buyNowPriceCents  Int?
  buyNowExpiresAt   DateTime?
  startAt           DateTime
  endAt             DateTime
  status            String    // DRAFT | LIVE | SOLD | ENDED
  conditionGrade    ConditionGrade?
  conditionSummary  String?   @db.Text
  imperfections     Json?
  latitude          Float?
  longitude         Float?
  locationZip       String?
  createdAt         DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  seller  User          @relation("Seller", fields: [sellerId], references: [id], onDelete: Cascade)
  buyer   User?         @relation("Buyer", fields: [buyerId], references: [id], onDelete: SetNull)
  images  AuctionImage[]
  damageImages AuctionDamageImage[]
  bids    Bid[]
  autoBids AutoBid[]
  feedbacks AuctionFeedback[]
  trafficEvents      TrafficEvent[]
  marketingCampaigns Campaign[]
  auctionAnalytics   AuctionAnalytics[]
  promoPosts         Post[]           @relation("AuctionPromoPosts")

  @@index([sellerId])
  @@index([buyerId])
  @@index([status])
  @@index([endAt])
  @@index([make, model, year])
  @@index([status, endAt])
  @@index([status, createdAt])
  @@index([latitude, longitude])
}

model AuctionImage {
  id        String   @id @default(cuid())
  auctionId String
  url       String
  sortOrder Int      @default(0)

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@index([auctionId])
}

model AuctionDamageImage {
  id        String   @id @default(cuid())
  auctionId String
  label     String
  imageUrl  String
  createdAt DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@index([auctionId])
}

model AuctionFeedback {
  id         String         @id @default(cuid())
  auctionId  String
  fromUserId String
  toUserId   String
  rating     FeedbackRating
  note       String?        @db.VarChar(500)
  createdAt  DateTime       @default(now())

  auction  Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  fromUser User    @relation("FeedbackFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User    @relation("FeedbackTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([auctionId, fromUserId])
  @@index([toUserId])
  @@index([auctionId])
}

model Bid {
  id        String   @id @default(cuid())
  auctionId String
  bidderId  String
  amountCents Int
  createdAt DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidder User     @relation(fields: [bidderId], references: [id], onDelete: Cascade)

  @@index([auctionId])
  @@index([bidderId])
}

model AutoBid {
  id            String   @id @default(cuid())
  auctionId     String
  bidderId      String
  maxAmountCents Int
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidder User     @relation(fields: [bidderId], references: [id], onDelete: Cascade)

  @@unique([auctionId, bidderId])
  @@index([auctionId])
}

model Notification {
  id         String    @id @default(cuid())
  userId     String
  type       String
  payloadJson String
  createdAt  DateTime  @default(now())
  readAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, readAt])
}

model ReputationEvent {
  id         String             @id @default(cuid())
  userId     String
  type       ReputationEventType
  points     Int
  basePoints Int
  meta       Json?
  createdAt  DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, type])
}

model TrafficEvent {
  id        String                  @id @default(cuid())
  auctionId String
  userId    String?
  eventType MarketingTrafficEventType
  source    MarketingTrafficSource  @default(UNKNOWN)
  metadata  Json?
  createdAt DateTime                @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([auctionId])
  @@index([auctionId, createdAt])
  @@index([userId])
}

/// Daily rollups for VIEW / SHARE_CLICK only (UTC calendar day). Rebuilt via backfill; incremented on ingest.
model AuctionAnalytics {
  id          String    @id @default(cuid())
  auctionId   String
  day         DateTime  @db.Date
  views       Int       @default(0)
  shareClicks Int       @default(0)
  lastEventAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@unique([auctionId, day])
  @@index([auctionId])
}

model Campaign {
  id        String                  @id @default(cuid())
  auctionId String
  userId    String
  name      String
  type      String
  status    MarketingCampaignStatus   @default(DRAFT)
  startAt   DateTime?
  endAt     DateTime?
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  auction Auction         @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  events  CampaignEvent[]

  @@index([userId])
  @@index([auctionId])
  @@index([userId, status])
}

model CampaignEvent {
  id         String   @id @default(cuid())
  campaignId String
  eventType  String
  metadata   Json?
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([campaignId, createdAt])
}
