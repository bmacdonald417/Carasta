generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum ConditionGrade {
  CONCOURS
  EXCELLENT
  VERY_GOOD
  GOOD
  FAIR
}

enum FeedbackRating {
  POSITIVE
  NEGATIVE
}

enum CollectorTier {
  NEW
  VERIFIED
  ELITE
  APEX
}

enum ReputationEventType {
  PAYMENT_VERIFIED
  DELIVERY_CONFIRMED
  PURCHASE_COMPLETED
  SALE_COMPLETED
  POSITIVE_FEEDBACK
  NEGATIVE_FEEDBACK
  CONDITION_REPORT_QUALITY
  DISPUTE_OPENED
  DISPUTE_LOST
  CHARGEBACK
  SELLER_CANCELLATION_AFTER_BID
  BUYER_NONPAYMENT
  POLICY_VIOLATION
  SOCIAL_HELPFUL_UPVOTE
  SOCIAL_SPAM_FLAG
}

enum MarketingTrafficEventType {
  VIEW
  SHARE_CLICK
  BID_CLICK
  EXTERNAL_REFERRAL
}

enum MarketingTrafficSource {
  DIRECT
  INSTAGRAM
  FACEBOOK
  LINKEDIN
  TIKTOK
  EMAIL
  CARMUNITY
  UNKNOWN
}

enum MarketingCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

/// Seller workspace checklist row — distinct from [Campaign] outreach records.
enum ListingMarketingTaskStatus {
  PENDING
  COMPLETED
}

enum ListingMarketingTaskType {
  CHECKLIST
  REMINDER
  MILESTONE
  CUSTOM
}

enum ListingMarketingArtifactType {
  CAPTION
  HEADLINE
  BODY
  HASHTAGS
  OTHER
}

/// Discussion reactions (threads & replies). Distinct from feed Post [Like].
enum DiscussionReactionKind {
  LIKE
  FIRE
  WRENCH
  MIND_BLOWN
  LAUGH
  RESPECT
  DISLIKE
}

enum DiscussionReportReason {
  harassment
  spam
  hate
  illegal
  self_harm
  explicit
  misinformation
  off_topic
  other
}

enum DiscussionReportStatus {
  OPEN
  REVIEWING
  ACTIONED
  DISMISSED
}

/// Carasta Coin — wallet / ledger domain enums (centralized, token-ready).
enum WalletTransactionKind {
  GRANT
  DEBIT
  REVERSAL
  HOLD
  RELEASE
  EXPIRATION
  ADMIN_ADJUSTMENT
  REDEMPTION
}

enum WalletTransactionStatus {
  PENDING
  POSTED
  REVERSED
  VOID
}

enum RewardEventSource {
  SYSTEM
  USER
  ADMIN
  CAMPAIGN
}

enum RewardEventStatus {
  RECEIVED
  HELD
  AWARDED
  DENIED
  REVERSED
}

enum RewardReasonCode {
  ACCOUNT_CREATED
  PROFILE_VERIFIED
  KYC_COMPLETED
  FIRST_LISTING
  LISTING_QUALITY
  REFERRAL_SIGNUP
  REFERRAL_ONBOARDING
  REFERRAL_FIRST_LISTING
  SALE_COMPLETED
  COMMUNITY_CONTRIBUTION
  PROMOTION_BONUS
  ADMIN_MANUAL
}

enum RewardRuleStatus {
  ACTIVE
  PAUSED
  DISABLED
}

enum RedemptionType {
  FEATURED_LISTING_BOOST
  SELLER_ANALYTICS_UNLOCK
  PREMIUM_BADGE
  LISTING_PLACEMENT_ENHANCEMENT
  SELLER_FEE_CREDIT
  PREMIUM_TOOL_ACCESS
  EARLY_ACCESS_PERK
  OTHER
}

enum RedemptionStatus {
  REQUESTED
  APPROVED
  FULFILLED
  DENIED
  REVERSED
}

enum FraudFlagStatus {
  OPEN
  REVIEWING
  ACTIONED
  DISMISSED
}

enum FraudFlagSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RewardCampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  ENDED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String?
  handle       String    @unique
  name         String?
  bio          String?
  avatarUrl    String?
  location     String?
  image        String?
  emailVerified DateTime?
  acceptedTermsAt DateTime?
  acceptedPrivacyAt DateTime?
  acceptedCommunityGuidelinesAt DateTime?
  /// Seeded Carmunity demo profile — safe to delete in bulk; see CARMUNITY_DISCUSSIONS_DEMO_CONTENT.md
  isDemoSeed   Boolean   @default(false)
  role         Role      @default(USER)
  instagramUrl String?
  facebookUrl  String?
  twitterUrl   String?
  tiktokUrl    String?
  accounts     Account[]
  sessions     Session[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  followers    Follow[]  @relation("Following")
  following    Follow[]  @relation("Follower")
  posts        Post[]
  likes        Like[]
  postReactions PostReaction[]
  comments     Comment[]
  garageCars   GarageCar[]
  auctions     Auction[]  @relation("Seller")
  purchasedAuctions Auction[] @relation("Buyer")
  bids         Bid[]
  autoBids     AutoBid[]
  notifications Notification[]
  reputationEvents ReputationEvent[]
  feedbackGiven   AuctionFeedback[] @relation("FeedbackFrom")
  feedbackReceived AuctionFeedback[] @relation("FeedbackTo")

  reputationScore       Int           @default(0)
  collectorTier         CollectorTier @default(NEW)
  reputationUpdatedAt   DateTime?
  completedSalesCount   Int           @default(0)
  completedPurchasesCount Int         @default(0)
  disputesLostCount     Int           @default(0)
  uniqueCounterpartyCount Int         @default(0)
  weeklyMarketingDigestOptIn Boolean @default(false)
  lastMarketingDigestSentAt DateTime?

  trafficEventsAsViewer TrafficEvent[]
  marketingCampaigns    Campaign[]
  marketingPresets      MarketingPreset[]

  forumThreads ForumThread[]
  forumReplies ForumReply[]
  forumThreadReactions ForumThreadReaction[]
  forumReplyReactions ForumReplyReaction[]
  userBadges UserBadge[]
  auctionWatches AuctionWatch[]
  /// Outbound Carmunity / system notifications where this user is the actor.
  notificationsSent Notification[] @relation("NotificationActor")
  discussionReportsSubmitted DiscussionReport[] @relation("DiscussionReportReporter")
  discussionReportsReviewed DiscussionReport[] @relation("DiscussionReportReviewer")

  forumThreadsHidden ForumThread[] @relation("ForumThreadHiddenBy")
  forumRepliesHidden ForumReply[] @relation("ForumReplyHiddenBy")
  blocksGiven          UserBlock[] @relation("UserBlockBlocker")
  blocksReceived       UserBlock[] @relation("UserBlockBlocked")
  mutesGiven           UserMute[]  @relation("UserMuteMuter")
  mutesReceived        UserMute[]  @relation("UserMuteMuted")
  forumThreadSubscriptions ForumThreadSubscription[]

  /// In-app element feedback (site UX kit); distinct from auction peer feedback.
  elementFeedbacks ElementFeedback[]

  /// Phase K: null until onboarding finished or skipped — existing users backfilled in migration.
  carmunityOnboardingCompletedAt DateTime?
  /// Phase K: JSON { gearSlugs?: string[], lowerCategories?: { spaceSlug: string; slug: string }[] }
  carmunityInterestPrefs Json?

  /// P1 seller marketing workspace plans this user created (seller-owned listing scope).
  listingMarketingPlansCreated ListingMarketingPlan[] @relation("ListingMarketingPlanCreator")
  /// P3: auditable AI copilot generations for this user.
  marketingCopilotRuns MarketingCopilotRun[]
  /// Seller listing copy AI (sell wizard / optional draft scope).
  listingAiRuns ListingAiRun[]

  /// Phase Q: messaging participation and sent messages.
  conversationParticipants ConversationParticipant[]
  messagesSent             Message[]

  /// Carasta Coin — rewards wallet & audit trail.
  wallet                UserWallet?
  walletTransactions     WalletTransaction[]     @relation("WalletTransactionUser")
  walletEvents           RewardEvent[]           @relation("RewardEventUser")
  referralCode           ReferralCode?
  referralsSent          ReferralRelationship[]  @relation("ReferralReferrer")
  referralsReceived      ReferralRelationship[]  @relation("ReferralReferred")
  fraudFlags             FraudFlag[]             @relation("FraudFlagUser")
  adminAdjustmentsMade   AdminAdjustment[]       @relation("AdminAdjustmentActor")

  /// Carasta Coin — redemptions and campaign participation.
  redemptionRecords      RedemptionRecord[]
  rewardCampaignParticipations RewardCampaignParticipation[]
  fraudFlagsReviewed     FraudFlag[]            @relation("FraudFlagReviewer")
  adminAdjustmentsReceived AdminAdjustment[]
}

/// Top-level Carmunity forum area (e.g. Mechanics Corner, Gear Interests). Distinct from feed [Post].
model ForumSpace {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?  @db.Text
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  categories ForumCategory[]

  @@index([isActive, sortOrder])
}

/// Category within a space (thread bucket). Slugs are unique per space.
model ForumCategory {
  id          String   @id @default(cuid())
  spaceId     String
  slug        String
  title       String
  description String?  @db.Text
  sortOrder   Int      @default(0)
  /// Optional structured tags (e.g. make/model) — evolve without schema churn.
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  space   ForumSpace    @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  threads ForumThread[]

  @@unique([spaceId, slug])
  @@index([spaceId, sortOrder])
}

/// Discussion thread — title + body; not a [Post] (no feed like/auction promo semantics).
model ForumThread {
  id             String   @id @default(cuid())
  categoryId     String
  authorId       String
  /// Phase M: optional link to a Carasta listing — canonical discussion anchor for that auction.
  auctionId      String?
  title          String
  body           String   @db.Text
  replyCount     Int      @default(0)
  lastActivityAt DateTime @default(now())
  locked         Boolean  @default(false)
  /// Seeded demo thread — see CARMUNITY_DISCUSSIONS_DEMO_CONTENT.md
  isDemoSeed     Boolean  @default(false)
  /// Soft moderation hide — record kept; non-admins do not see in lists or thread view.
  isHidden       Boolean  @default(false)
  hiddenAt       DateTime?
  hiddenById     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  category ForumCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  author   User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  auction  Auction?      @relation(fields: [auctionId], references: [id], onDelete: SetNull)
  hiddenBy User?         @relation("ForumThreadHiddenBy", fields: [hiddenById], references: [id], onDelete: SetNull)
  replies  ForumReply[]
  threadReactions ForumThreadReaction[]
  discussionReports DiscussionReport[]
  subscriptions ForumThreadSubscription[]

  @@index([categoryId, lastActivityAt])
  @@index([authorId])
  @@index([auctionId])
}

/// User saved / followed a thread for retention (Phase I). Distinct from auction watchlist.
model ForumThreadSubscription {
  id        String   @id @default(cuid())
  userId    String
  threadId  String
  createdAt DateTime @default(now())
  /// Last time the subscriber opened the thread (Phase J); used for lightweight “new activity” on saves.
  lastViewedAt DateTime?

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@unique([userId, threadId])
  @@index([userId])
  @@index([threadId])
}

model ForumReply {
  id        String   @id @default(cuid())
  threadId  String
  authorId  String
  /// When set, this reply is nested under another reply in the same thread (Phase F).
  parentReplyId String?
  body      String   @db.Text
  /// Seeded demo reply — see CARMUNITY_DISCUSSIONS_DEMO_CONTENT.md
  isDemoSeed Boolean  @default(false)
  isHidden   Boolean  @default(false)
  hiddenAt   DateTime?
  hiddenById String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author User        @relation(fields: [authorId], references: [id], onDelete: Cascade)
  hiddenBy User?    @relation("ForumReplyHiddenBy", fields: [hiddenById], references: [id], onDelete: SetNull)
  parentReply ForumReply?  @relation("ForumReplyThread", fields: [parentReplyId], references: [id], onDelete: SetNull)
  childReplies ForumReply[] @relation("ForumReplyThread")
  replyReactions ForumReplyReaction[]
  discussionReports DiscussionReport[]

  @@index([threadId, createdAt])
  @@index([authorId])
  @@index([parentReplyId])
}

/// User-submitted moderation signal for Discussions (Phase G). Not a verdict.
model DiscussionReport {
  id           String                 @id @default(cuid())
  reporterId   String
  threadId     String?
  replyId      String?
  reason       DiscussionReportReason
  details      String?                @db.Text
  status       DiscussionReportStatus @default(OPEN)
  moderatorNote String?             @db.Text
  createdAt    DateTime               @default(now())
  reviewedAt   DateTime?
  reviewedById String?

  reporter   User         @relation("DiscussionReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)
  thread     ForumThread? @relation(fields: [threadId], references: [id], onDelete: Cascade)
  reply      ForumReply?  @relation(fields: [replyId], references: [id], onDelete: Cascade)
  reviewedBy User?        @relation("DiscussionReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([reporterId])
  @@index([threadId])
  @@index([replyId])
}

/// User A blocks user B — B’s discussions content is hidden from A only (Phase H).
model UserBlock {
  id         String   @id @default(cuid())
  blockerId  String
  blockedId  String
  createdAt  DateTime @default(now())

  blocker User @relation("UserBlockBlocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("UserBlockBlocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
  @@index([blockedId])
}

/// Muting reduces notification noise from a user; they may still appear in threads (Phase H).
model UserMute {
  id           String   @id @default(cuid())
  userId       String
  mutedUserId  String
  createdAt    DateTime @default(now())

  muter User @relation("UserMuteMuter", fields: [userId], references: [id], onDelete: Cascade)
  muted User @relation("UserMuteMuted", fields: [mutedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, mutedUserId])
  @@index([userId])
  @@index([mutedUserId])
}

model ForumThreadReaction {
  id        String                 @id @default(cuid())
  threadId String
  userId    String
  kind      DiscussionReactionKind
  createdAt DateTime               @default(now())
  updatedAt DateTime               @default(now()) @updatedAt

  thread ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// One reaction per user per thread (kind can change).
  @@unique([threadId, userId])
  @@index([threadId])
  @@index([userId])
}

model ForumReplyReaction {
  id        String                 @id @default(cuid())
  replyId   String
  userId    String
  kind      DiscussionReactionKind
  createdAt DateTime               @default(now())
  updatedAt DateTime               @default(now()) @updatedAt

  reply ForumReply @relation(fields: [replyId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  /// One reaction per user per reply (kind can change).
  @@unique([replyId, userId])
  @@index([replyId])
  @@index([userId])
}

/// Platform-defined badge (e.g. Top Contributor). Awarded via UserBadge.
model Badge {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?  @db.Text
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userBadges UserBadge[]
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

/// Seller-saved Share & Promote defaults (UTM campaign + copy options). Manual only.
model MarketingPreset {
  id              String   @id @default(cuid())
  userId          String
  name            String
  source          String
  medium          String
  campaignLabel   String?
  copyVariant     String
  includeHashtags Boolean  @default(true)
  includeKeywords Boolean  @default(true)
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, isDefault])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token     String?
  expires_at       Int?
  token_type       String?
  scope            String?
  id_token         String?
  session_state    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Post {
  id        String   @id @default(cuid())
  authorId  String
  /// Optional listing promoted via seller marketing → Carmunity (nullable for ordinary posts).
  auctionId String?
  content   String?
  imageUrl  String?
  createdAt DateTime @default(now())

  author  User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  auction Auction? @relation("AuctionPromoPosts", fields: [auctionId], references: [id], onDelete: SetNull)
  likes   Like[]
  comments Comment[]
  postReactions PostReaction[]

  @@index([authorId])
  @@index([createdAt])
  @@index([auctionId])
}

/// Carmunity feed post reactions — same kinds as discussion reactions (Phase Q).
model PostReaction {
  id        String                 @id @default(cuid())
  postId    String
  userId    String
  kind      DiscussionReactionKind
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model Like {
  userId String
  postId String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@id([userId, postId])
  @@index([postId])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([authorId])
}

model GarageCar {
  id        String   @id @default(cuid())
  ownerId   String
  type      String   // GARAGE | DREAM
  year      Int
  make      String
  model     String
  trim      String?
  notes     String?
  createdAt DateTime @default(now())

  owner  User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  images GarageCarImage[]

  @@index([ownerId])
  @@index([ownerId, type])
}

model GarageCarImage {
  id          String   @id @default(cuid())
  garageCarId String
  url         String
  sortOrder   Int      @default(0)

  garageCar GarageCar @relation(fields: [garageCarId], references: [id], onDelete: Cascade)

  @@index([garageCarId])
}

model Auction {
  id                String    @id @default(cuid())
  sellerId          String
  buyerId           String?
  title             String
  description       String?
  year              Int
  make              String
  model             String
  trim              String?
  vin               String?
  mileage           Int?
  reservePriceCents Int?
  buyNowPriceCents  Int?
  buyNowExpiresAt   DateTime?
  startAt           DateTime
  endAt             DateTime
  status            String    // DRAFT | LIVE | SOLD | ENDED
  conditionGrade    ConditionGrade?
  conditionSummary  String?   @db.Text
  imperfections     Json?
  latitude          Float?
  longitude         Float?
  locationZip       String?
  createdAt         DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  seller  User          @relation("Seller", fields: [sellerId], references: [id], onDelete: Cascade)
  buyer   User?         @relation("Buyer", fields: [buyerId], references: [id], onDelete: SetNull)
  images  AuctionImage[]
  damageImages AuctionDamageImage[]
  bids    Bid[]
  autoBids AutoBid[]
  feedbacks AuctionFeedback[]
  trafficEvents      TrafficEvent[]
  marketingCampaigns Campaign[]
  auctionAnalytics   AuctionAnalytics[]
  promoPosts         Post[]           @relation("AuctionPromoPosts")
  watches            AuctionWatch[]
  /// Phase M: Carmunity discussion threads anchored to this listing (nullable FK on ForumThread).
  discussionThreads  ForumThread[]
  /// P1: at most one structured marketing plan per listing (workspace foundation).
  listingMarketingPlan ListingMarketingPlan?
  /// P3: AI copilot runs tied to this listing.
  marketingCopilotRuns MarketingCopilotRun[]
  /// Listing copy AI runs optionally tied to this auction (draft or live).
  listingAiRuns ListingAiRun[]
  /// Phase R: listing-scoped conversations (DMs tied to this auction).
  conversations Conversation[]
  /// Carasta Coin — reward events tied to this listing.
  rewardEvents RewardEvent[]

  @@index([sellerId])
  @@index([buyerId])
  @@index([status])
  @@index([endAt])
  @@index([make, model, year])
  @@index([status, endAt])
  @@index([status, createdAt])
  @@index([latitude, longitude])
}

model AuctionImage {
  id        String   @id @default(cuid())
  auctionId String
  url       String
  sortOrder Int      @default(0)

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@index([auctionId])
}

/// User-saved auction for Carmunity watchlist (not bids, not garage inventory).
model AuctionWatch {
  id        String   @id @default(cuid())
  userId    String
  auctionId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@unique([userId, auctionId])
  @@index([userId])
  @@index([auctionId])
}

model AuctionDamageImage {
  id        String   @id @default(cuid())
  auctionId String
  label     String
  imageUrl  String
  createdAt DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@index([auctionId])
}

model AuctionFeedback {
  id         String         @id @default(cuid())
  auctionId  String
  fromUserId String
  toUserId   String
  rating     FeedbackRating
  note       String?        @db.VarChar(500)
  createdAt  DateTime       @default(now())

  auction  Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  fromUser User    @relation("FeedbackFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User    @relation("FeedbackTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([auctionId, fromUserId])
  @@index([toUserId])
  @@index([auctionId])
}

model Bid {
  id        String   @id @default(cuid())
  auctionId String
  bidderId  String
  amountCents Int
  createdAt DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidder User     @relation(fields: [bidderId], references: [id], onDelete: Cascade)

  @@index([auctionId])
  @@index([bidderId])
}

model AutoBid {
  id            String   @id @default(cuid())
  auctionId     String
  bidderId      String
  maxAmountCents Int
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidder User     @relation(fields: [bidderId], references: [id], onDelete: Cascade)

  @@unique([auctionId, bidderId])
  @@index([auctionId])
}

model Notification {
  id         String    @id @default(cuid())
  userId     String
  /// User who triggered this notification (discussions / social), when applicable.
  actorId    String?
  /// Focal entity id for dedupe (e.g. thread id, reply id). Optional for legacy rows.
  targetId   String?
  type       String
  payloadJson String
  createdAt  DateTime  @default(now())
  readAt     DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, readAt])
  @@index([userId, type, actorId, targetId, createdAt])
}

model ReputationEvent {
  id         String             @id @default(cuid())
  userId     String
  type       ReputationEventType
  points     Int
  basePoints Int
  meta       Json?
  createdAt  DateTime           @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, type])
}

model TrafficEvent {
  id        String                  @id @default(cuid())
  auctionId String
  userId    String?
  eventType MarketingTrafficEventType
  source    MarketingTrafficSource  @default(UNKNOWN)
  metadata  Json?
  createdAt DateTime                @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([auctionId])
  @@index([auctionId, createdAt])
  @@index([userId])
}

/// Daily rollups for VIEW / SHARE_CLICK only (UTC calendar day). Rebuilt via backfill; incremented on ingest.
model AuctionAnalytics {
  id          String    @id @default(cuid())
  auctionId   String
  day         DateTime  @db.Date
  views       Int       @default(0)
  shareClicks Int       @default(0)
  lastEventAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@unique([auctionId, day])
  @@index([auctionId])
}

model Campaign {
  id        String                  @id @default(cuid())
  auctionId String
  userId    String
  name      String
  type      String
  status    MarketingCampaignStatus   @default(DRAFT)
  startAt   DateTime?
  endAt     DateTime?
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt

  auction Auction         @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  events  CampaignEvent[]

  @@index([userId])
  @@index([auctionId])
  @@index([userId, status])
}

model CampaignEvent {
  id         String   @id @default(cuid())
  campaignId String
  eventType  String
  metadata   Json?
  createdAt  DateTime @default(now())

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([campaignId, createdAt])
}

/// Structured seller marketing workspace for a single listing — additive to [Campaign] / analytics.
model ListingMarketingPlan {
  id          String   @id @default(cuid())
  auctionId  String   @unique
  createdById String
  objective   String   @default("") @db.Text
  audience    String   @default("") @db.Text
  positioning String   @default("") @db.Text
  /// Selected channel keys, e.g. ["carmunity","instagram"] — evolve without enum churn.
  channels    Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  auction   Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  createdBy User    @relation("ListingMarketingPlanCreator", fields: [createdById], references: [id], onDelete: Cascade)

  tasks     ListingMarketingTask[]
  artifacts ListingMarketingArtifact[]

  @@index([createdById])
}

model ListingMarketingTask {
  id          String                     @id @default(cuid())
  planId      String
  type        ListingMarketingTaskType   @default(CHECKLIST)
  title       String
  description String                     @default("") @db.Text
  channel     String?
  status      ListingMarketingTaskStatus   @default(PENDING)
  sortOrder   Int                        @default(0)
  completedAt DateTime?

  plan ListingMarketingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId, sortOrder])
}

model ListingMarketingArtifact {
  id        String                       @id @default(cuid())
  planId    String
  type      ListingMarketingArtifactType @default(OTHER)
  channel   String                       @default("")
  content   String                       @db.Text
  version   Int                          @default(1)
  createdAt DateTime                     @default(now())

  plan ListingMarketingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId, createdAt])
}

/// P3: persisted AI copilot generation for audit, rate limits, and optional apply linkage.
model MarketingCopilotRun {
  id          String    @id @default(cuid())
  auctionId   String
  createdById String
  intakeJson  Json
  outputJson  Json
  inputHash   String
  outputHash  String
  model       String
  createdAt   DateTime  @default(now())
  appliedAt   DateTime?

  auction   Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  createdBy User    @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([createdById, createdAt])
  @@index([auctionId, createdAt])
}

/// Auditable OpenAI-backed listing copy generations (sell flow / draft refine).
model ListingAiRun {
  id          String   @id @default(cuid())
  createdById String
  /// When refining an existing saved draft or listing; null for wizard-only runs.
  auctionId   String?
  intakeJson  Json
  outputJson  Json
  model       String
  createdAt   DateTime @default(now())

  createdBy User     @relation(fields: [createdById], references: [id], onDelete: Cascade)
  auction   Auction? @relation(fields: [auctionId], references: [id], onDelete: SetNull)

  @@index([createdById, createdAt])
  @@index([auctionId, createdAt])
}

/// Phase Q: 1:1 messaging conversation container. A `directKey` is used to dedupe direct threads.
model Conversation {
  id                 String    @id @default(cuid())
  /// Optional listing scope (Phase R). Null means generic DMs.
  auctionId           String?
  /// For direct 1:1 threads, includes scope:
  /// - Generic: `${minUserId}:${maxUserId}:g`
  /// - Listing: `${minUserId}:${maxUserId}:a:${auctionId}`
  directKey          String?   @unique
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  lastMessageAt      DateTime?
  lastMessagePreview String?   @db.VarChar(240)

  auction       Auction? @relation(fields: [auctionId], references: [id], onDelete: SetNull)
  participants ConversationParticipant[]
  messages      Message[]

  @@index([lastMessageAt])
  @@index([auctionId])
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  lastReadAt     DateTime?
  /// Reserved for Phase R; not yet enforced anywhere.
  isMuted        Boolean  @default(false)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  body           String       @db.Text
  createdAt      DateTime     @default(now())
  isEdited       Boolean      @default(false)
  isSystem       Boolean      @default(false)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
}

/// Single wallet per user for Carasta Coin (cached balances; ledger is source of truth).
model UserWallet {
  id               String   @id @default(cuid())
  userId           String   @unique
  balanceAvailable Int      @default(0)
  balancePending   Int      @default(0)
  lifetimeEarned   Int      @default(0)
  lifetimeSpent    Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions WalletTransaction[]
  redemptions  RedemptionRecord[]

  @@index([userId])
}

/// Immutable ledger entry for every Carasta Coin movement.
model WalletTransaction {
  id               String                  @id @default(cuid())
  walletId         String
  userId           String
  kind             WalletTransactionKind
  status           WalletTransactionStatus @default(POSTED)
  amount           Int
  currency         String                  @default("CARASTA_COIN")
  reasonCode       RewardReasonCode?
  description      String?                 @db.VarChar(300)
  idempotencyKey   String?
  relatedEventId   String?
  relatedTxnId     String?
  rewardCampaignId       String?
  redemptionId     String?
  adminAdjustmentId String?
  expiresAt        DateTime?
  metadata         Json?
  createdAt        DateTime                @default(now())

  wallet     UserWallet           @relation(fields: [walletId], references: [id], onDelete: Cascade)
  user       User                 @relation("WalletTransactionUser", fields: [userId], references: [id], onDelete: Cascade)
  event      RewardEvent?         @relation(fields: [relatedEventId], references: [id], onDelete: SetNull)
  relatedTxn WalletTransaction?   @relation("WalletTransactionRelated", fields: [relatedTxnId], references: [id], onDelete: SetNull)
  reversals  WalletTransaction[]  @relation("WalletTransactionRelated")
  rewardCampaign   RewardCampaign?            @relation(fields: [rewardCampaignId], references: [id], onDelete: SetNull)
  redemption RedemptionRecord?    @relation(fields: [redemptionId], references: [id], onDelete: SetNull)
  adminAdjustment AdminAdjustment? @relation(fields: [adminAdjustmentId], references: [id], onDelete: SetNull)

  @@index([walletId, createdAt])
  @@index([userId, createdAt])
  @@index([kind, createdAt])
  @@index([relatedEventId])
  @@unique([userId, idempotencyKey])
}

/// Reward-triggering event (separate from ledger posting for idempotency & audit).
model RewardEvent {
  id             String            @id @default(cuid())
  userId         String
  source         RewardEventSource @default(SYSTEM)
  reasonCode     RewardReasonCode
  status         RewardEventStatus @default(RECEIVED)
  idempotencyKey String
  ruleId         String?
  rewardCampaignId     String?
  auctionId      String?
  metadata       Json?
  createdAt      DateTime          @default(now())
  decidedAt      DateTime?

  user     User        @relation("RewardEventUser", fields: [userId], references: [id], onDelete: Cascade)
  rule     RewardRule? @relation(fields: [ruleId], references: [id], onDelete: SetNull)
  rewardCampaign RewardCampaign?   @relation(fields: [rewardCampaignId], references: [id], onDelete: SetNull)
  auction  Auction?    @relation(fields: [auctionId], references: [id], onDelete: SetNull)
  txns     WalletTransaction[]

  @@unique([userId, idempotencyKey])
  @@index([userId, createdAt])
  @@index([reasonCode, createdAt])
  @@index([status, createdAt])
}

/// Configurable reward rule (admin-managed).
model RewardRule {
  id          String           @id @default(cuid())
  code        String           @unique
  status      RewardRuleStatus @default(ACTIVE)
  reasonCode  RewardReasonCode
  amount      Int
  isHold      Boolean          @default(false)
  holdDays    Int?
  maxAwardsPerUser Int?
  cooldownSeconds Int?
  startsAt    DateTime?
  endsAt      DateTime?
  metadata    Json?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  events RewardEvent[]

  @@index([status])
  @@index([reasonCode])
}

/// Referral code per user (shareable).
model ReferralCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  code      String   @unique
  createdAt DateTime @default(now())
  disabledAt DateTime?
  metadata  Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  relationships ReferralRelationship[]
}

/// Referral relationship (referrer -> referred).
model ReferralRelationship {
  id             String   @id @default(cuid())
  referrerId     String
  referredId     String   @unique
  referralCodeId String?
  createdAt      DateTime @default(now())
  metadata       Json?

  referrer User @relation("ReferralReferrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("ReferralReferred", fields: [referredId], references: [id], onDelete: Cascade)
  referralCode ReferralCode? @relation(fields: [referralCodeId], references: [id], onDelete: SetNull)

  @@unique([referrerId, referredId])
  @@index([referrerId, createdAt])
}

model RedemptionOption {
  id          String         @id @default(cuid())
  code        String         @unique
  type        RedemptionType
  title       String
  description String?        @db.Text
  cost        Int
  isActive    Boolean        @default(true)
  metadata    Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  redemptions RedemptionRecord[]

  @@index([isActive])
  @@index([type])
}

model RedemptionRecord {
  id          String           @id @default(cuid())
  userId      String
  walletId    String
  optionId    String
  status      RedemptionStatus @default(REQUESTED)
  cost        Int
  notes       String?          @db.Text
  metadata    Json?
  createdAt   DateTime         @default(now())
  decidedAt   DateTime?
  fulfilledAt DateTime?

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet  UserWallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)
  option  RedemptionOption @relation(fields: [optionId], references: [id], onDelete: Restrict)
  txns    WalletTransaction[]

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model RewardCampaign {
  id          String         @id @default(cuid())
  code        String         @unique
  title       String
  description String?        @db.Text
  status      RewardCampaignStatus @default(DRAFT)
  startsAt    DateTime?
  endsAt      DateTime?
  metadata    Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  participations RewardCampaignParticipation[]
  events         RewardEvent[]
  txns           WalletTransaction[]

  @@index([status])
}

model RewardCampaignParticipation {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  joinedAt   DateTime @default(now())
  metadata   Json?

  campaign RewardCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([campaignId, userId])
  @@index([userId, joinedAt])
}

model FraudFlag {
  id          String            @id @default(cuid())
  userId      String
  status      FraudFlagStatus   @default(OPEN)
  severity    FraudFlagSeverity @default(MEDIUM)
  reason      String
  metadata    Json?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  reviewedAt  DateTime?
  reviewedById String?

  user       User   @relation("FraudFlagUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User?  @relation("FraudFlagReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model AdminAdjustment {
  id        String   @id @default(cuid())
  userId    String
  actorId   String
  kind      WalletTransactionKind
  amount    Int
  reason    String
  metadata  Json?
  createdAt DateTime @default(now())

  user  User @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor User @relation("AdminAdjustmentActor", fields: [actorId], references: [id], onDelete: Cascade)
  txns  WalletTransaction[]

  @@index([userId, createdAt])
  @@index([actorId, createdAt])
}

/// Site element feedback (Element Feedback Kit). Table name `feedback` for SQL parity with the kit.
model ElementFeedback {
  id                String    @id @default(cuid())
  organizationId    String
  userId            String?
  content           String    @db.Text
  category          String
  pageUrl           String?
  elementSelector   String?
  elementText       String?   @db.Text
  elementType       String?
  elementIdAttr     String?
  elementClassAttr  String?
  status            String    @default("pending")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  resolvedAt        DateTime?
  resolutionCommitSha String?
  resolutionCommitUrl String?
  resolutionSummary   String?   @db.Text
  resolutionFiles     Json?

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, createdAt])
  @@map("feedback")
}

model AgentRun {
  id             String    @id @default(cuid())
  organizationId String
  type           String
  status         String    @default("running")
  createdAt      DateTime  @default(now())
  completedAt    DateTime?

  events AgentRunEvent[]

  @@index([organizationId, status])
  @@map("agent_runs")
}

model AgentRunEvent {
  id        String   @id @default(cuid())
  runId     String
  kind      String
  payload   Json?
  createdAt DateTime @default(now())

  run AgentRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId, createdAt])
  @@map("agent_run_events")
}
