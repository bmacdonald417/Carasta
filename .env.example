# Database (PostgreSQL)
DATABASE_URL="postgresql://user:password@localhost:5432/aurum?schema=public"

# Seller Marketing dashboard (/u/[handle]/marketing). Omit or set false in production until ready.
# MARKETING_ENABLED="true"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# Google OAuth (optional)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# UploadThing (optional, for file uploads)
# UPLOADTHING_TOKEN=""

# Pusher (optional, for real-time bid updates)
# PUSHER_APP_ID=""
# PUSHER_KEY=""
# PUSHER_SECRET=""
# PUSHER_CLUSTER="us2"
# NEXT_PUBLIC_PUSHER_KEY=""
# NEXT_PUBLIC_PUSHER_CLUSTER="us2"
