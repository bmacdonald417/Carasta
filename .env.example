# =============================================================================
# Carasta / Aurum — environment variables
# Copy to `.env` locally. On Railway (canonical project: Carasta), set the same
# logical keys in the service Variables UI (do not commit real secrets).
# =============================================================================
#
# Legend:
#   REQUIRED     — app/build fails or auth is unsafe without it
#   RECOMMENDED  — production correctness (URLs, marketing, emails)
#   OPTIONAL     — feature-gated or ops/scripts only
#
# This file mirrors what the codebase reads (`process.env.*` and Prisma).
# =============================================================================

# -----------------------------------------------------------------------------
# Database (REQUIRED for Prisma, `npm run build`, runtime)
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/aurum?schema=public"

# -----------------------------------------------------------------------------
# NextAuth (REQUIRED for sessions, JWT minting, `getToken` in API routes)
# -----------------------------------------------------------------------------
# Public URL of this app — must match the browser origin in production (https).
NEXTAUTH_URL="http://localhost:3000"
# Strong random secret — used to sign cookies and Carmunity/mobile JWTs.
# Generate e.g.: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# -----------------------------------------------------------------------------
# Public site URL (RECOMMENDED in production)
# -----------------------------------------------------------------------------
# Used for absolute marketing links (`lib/marketing/site-origin.ts`) and as a
# fallback base for Carmunity multipart upload responses when
# CARMUNITY_MEDIA_PUBLIC_BASE_URL is unset. If unset, server falls back to
# NEXTAUTH_URL, then Railway/Vercel-style `VERCEL_URL`, then localhost.
# NEXT_PUBLIC_SITE_URL="https://your-production-domain.com"

# -----------------------------------------------------------------------------
# Google OAuth (OPTIONAL — omit both to disable “Sign in with Google” UI)
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Seller marketing feature flag (RECOMMENDED if you use marketing tools)
# -----------------------------------------------------------------------------
# Must be the literal string "true" or marketing routes/nav stay off.
# MARKETING_ENABLED="true"

# -----------------------------------------------------------------------------
# Marketing track beacon + admin observability (OPTIONAL)
# -----------------------------------------------------------------------------
# `POST /api/marketing/track` and related flows use NEXTAUTH_SECRET for JWT decode.
# Verbose structured logs for the track route (1 / true / yes).
# MARKETING_TRACK_OBSERVABILITY_VERBOSE="1"

# Bearer secret (min 16 chars) for machine access to:
#   GET /api/admin/marketing-track-observability
#   GET /api/admin/marketing-snapshot-observability
# (Admins can also use a signed-in ADMIN session when configured.)
# MARKETING_TRACK_OBSERVABILITY_SECRET=""

# Verbose logs for GET /api/admin/marketing/snapshot (1 / true / yes).
# ADMIN_MARKETING_SNAPSHOT_OBSERVABILITY_VERBOSE="1"

# -----------------------------------------------------------------------------
# Weekly marketing digest (OPTIONAL — Resend + explicit send flag)
# -----------------------------------------------------------------------------
# RESEND_API_KEY=""
# MARKETING_DIGEST_FROM="Carasta <digest@your-verified-domain.com>"
# Must be literal "true" for real sends (CLI `npm run marketing:send-digest` and hosted job).
# MARKETING_DIGEST_SEND_ENABLED="true"

# Hosted cron: GET|POST /api/jobs/marketing-digest — Bearer or ?secret= (min 16 chars).
# MARKETING_DIGEST_CRON_SECRET=""

# CLI only: skip ~6.5-day spacing when sending digests manually (`MARKETING_DIGEST_FORCE=1`).
# MARKETING_DIGEST_FORCE="1"

# -----------------------------------------------------------------------------
# Real-time (OPTIONAL — Pusher)
# -----------------------------------------------------------------------------
# Server: all of PUSHER_APP_ID, PUSHER_KEY, PUSHER_SECRET required for broadcasts.
# Client: NEXT_PUBLIC_PUSHER_KEY required for live UI subscription (see auction detail + activity feed).
# PUSHER_APP_ID=""
# PUSHER_KEY=""
# PUSHER_SECRET=""
# PUSHER_CLUSTER="us2"
# NEXT_PUBLIC_PUSHER_KEY=""
# NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# -----------------------------------------------------------------------------
# Carmunity media uploads (OPTIONAL)
# -----------------------------------------------------------------------------
# Canonical public base for returned `imageUrl` from POST /api/carmunity/media/upload
# (no trailing slash). If unset, uses NEXT_PUBLIC_SITE_URL, then the request origin.
# CARMUNITY_MEDIA_PUBLIC_BASE_URL="https://your-production-domain.com"

# -----------------------------------------------------------------------------
# Traffic event pruning script (OPTIONAL — `npm run marketing:prune-traffic-events`)
# -----------------------------------------------------------------------------
# TRAFFIC_EVENT_RETENTION_DAYS="365"
# TRAFFIC_EVENT_PRUNE_DRY_RUN="true"
# TRAFFIC_EVENT_PRUNE_ENABLED="true"

# -----------------------------------------------------------------------------
# Platform-provided (do not set manually unless you know why)
# -----------------------------------------------------------------------------
# NODE_ENV       — "development" | "production" (set by Node / hosting)
# VERCEL_URL     — hostname only, set on Vercel; used as site-origin fallback

# -----------------------------------------------------------------------------
# Build / hosting (OPTIONAL — often set in Railway Variables, not in .env)
# -----------------------------------------------------------------------------
# NIXPACKS_NODE_VERSION=20   — aligns Nixpacks Node with package.json "engines"

# -----------------------------------------------------------------------------
# Not used by current in-repo routes (dependency may exist for future use)
# -----------------------------------------------------------------------------
# UploadThing env vars are not referenced under app/ or lib/; add only if you wire UploadThing.
