# =============================================================================
# Carasta / Aurum — environment variable *template* (committed)
# =============================================================================
#
# Put real values in `.env` (gitignored). Keep `.env` aligned with Railway; treat
# it as the source of truth for keys and values on your machine. This file only
# documents names, intent, and safe placeholders — never paste private DB URLs or
# production secrets here. Cursor / CI should not treat this file as a secret store.
#
# Legend:
#   REQUIRED     — app/build fails or auth is unsafe without it
#   RECOMMENDED  — production correctness (URLs, marketing, emails)
#   OPTIONAL     — feature-gated or ops/scripts only
#
# Variable names match what the app and Prisma read (`process.env.*`, prisma/schema.prisma).
# =============================================================================

# -----------------------------------------------------------------------------
# Database (REQUIRED for Prisma; see security model below)
# -----------------------------------------------------------------------------
# Prisma reads DATABASE_URL only (prisma/schema.prisma).
#
# Security model (recommended):
#   DATABASE_URL         — Private Railway Postgres hostname (*.railway.internal).
#                          Set on the **Carasta web service** in Railway for **runtime**
#                          (Next + Prisma at `npm start`). Do not put this value in Cursor,
#                          CI, or this template file.
#   DATABASE_PUBLIC_URL  — Public TCP proxy URL (*.proxy.rlwy.net or similar). Safe for
#                          local `.env`, Cursor, CI, and for Nixpacks **build** (see
#                          scripts/build-with-public-db.cjs). Never commit the real string here.
#
# Railway web service: keep **both** DATABASE_URL (private, runtime) and DATABASE_PUBLIC_URL
# (public, build) in Variables unless your build network can reach DATABASE_URL as-is.
#
# Local development:
#   Prefer DATABASE_PUBLIC_URL in your `.env`. If DATABASE_URL is unset or empty,
#   `npm run dev` and `npm run db:*` use scripts/run-with-local-db.cjs to copy
#   DATABASE_PUBLIC_URL → DATABASE_URL for that process only.
#   Alternatively, set DATABASE_URL in `.env` to the public proxy only (gitignored) if you
#   want a single key; DATABASE_PUBLIC_URL can stay unset in that case.
#
DATABASE_PUBLIC_URL="postgresql://USER:PASSWORD@YOUR-PROXY-HOST:PORT/railway"
# DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/carasta"

# -----------------------------------------------------------------------------
# NextAuth (REQUIRED for sessions, JWT minting, `getToken` in API routes)
# -----------------------------------------------------------------------------
# Public URL of this app — must match the browser origin in production (https).
NEXTAUTH_URL="http://localhost:3000"
# Strong random secret — used to sign cookies and Carmunity/mobile JWTs.
# Generate e.g.: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# -----------------------------------------------------------------------------
# Public site URL (RECOMMENDED in production)
# -----------------------------------------------------------------------------
# Used for absolute marketing links (`lib/marketing/site-origin.ts`) and as a
# fallback base for Carmunity multipart upload responses when
# CARMUNITY_MEDIA_PUBLIC_BASE_URL is unset. If unset, server falls back to
# NEXTAUTH_URL, then Railway/Vercel-style `VERCEL_URL`, then localhost.
# NEXT_PUBLIC_SITE_URL="https://your-production-domain.com"

# -----------------------------------------------------------------------------
# Google OAuth (OPTIONAL — omit both to disable “Sign in with Google” UI)
# -----------------------------------------------------------------------------
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# Seller marketing feature flag (RECOMMENDED if you use marketing tools)
# -----------------------------------------------------------------------------
# Must be the literal string "true" or marketing routes/nav stay off.
# MARKETING_ENABLED="true"

# -----------------------------------------------------------------------------
# AI marketing copilot — Phase P2+ (OPTIONAL)
# -----------------------------------------------------------------------------
# Enables POST /api/marketing/copilot/generate, GET /api/marketing/copilot/runs?auctionId=…,
# and the seller workspace copilot UI.
# Server-only; never expose in NEXT_PUBLIC_*.
# OPENAI_API_KEY=""
# Optional Chat Completions model id (defaults to gpt-4o-mini). JSON object mode is used.
# MARKETING_COPILOT_MODEL="gpt-4o-mini"
#
# Phase P3 — quotas (each OpenAI-backed call creates a MarketingCopilotRun row):
# Per-user daily cap (UTC calendar day) and minimum seconds between runs.
# MARKETING_COPILOT_DAILY_LIMIT="25"
# MARKETING_COPILOT_COOLDOWN_SEC="45"

# -----------------------------------------------------------------------------
# AI listing assistant — sell wizard (OPTIONAL)
# -----------------------------------------------------------------------------
# Enables POST /api/listings/ai/generate, POST /api/listings/ai/rewrite-field,
# GET /api/listings/ai/runs?auctionId=…, and listing AI UI.
# Requires OPENAI_API_KEY (same server key as marketing copilot is fine).
# LISTING_AI_ENABLED="true"
# Optional model override (defaults to MARKETING_COPILOT_MODEL or gpt-4o-mini).
# LISTING_AI_MODEL="gpt-4o-mini"
# Per-user daily cap (UTC) and cooldown between listing AI calls (ListingAiRun rows).
# LISTING_AI_DAILY_LIMIT="20"
# LISTING_AI_COOLDOWN_SEC="45"

# -----------------------------------------------------------------------------
# Temporary review mode (OPTIONAL — pre-launch visual/product review only)
# -----------------------------------------------------------------------------
# Enables explicit temporary review access to selected surfaces without normal
# sign-in flow. This is intended to be removable later.
# REVIEW_MODE_ENABLED="true"
# NEXT_PUBLIC_REVIEW_MODE_ENABLED="true"
# REVIEW_MODE_DEMO_HANDLE="trackdaytom"
# REVIEW_MODE_PROFILE_HANDLE="nina_shift"

# -----------------------------------------------------------------------------
# Marketing track beacon + admin observability (OPTIONAL)
# -----------------------------------------------------------------------------
# `POST /api/marketing/track` and related flows use NEXTAUTH_SECRET for JWT decode.
# Verbose structured logs for the track route (1 / true / yes).
# MARKETING_TRACK_OBSERVABILITY_VERBOSE="1"

# Bearer secret (min 16 chars) for machine access to:
#   GET /api/admin/marketing-track-observability
#   GET /api/admin/marketing-snapshot-observability
# (Admins can also use a signed-in ADMIN session when configured.)
# MARKETING_TRACK_OBSERVABILITY_SECRET=""

# Verbose logs for GET /api/admin/marketing/snapshot (1 / true / yes).
# ADMIN_MARKETING_SNAPSHOT_OBSERVABILITY_VERBOSE="1"

# -----------------------------------------------------------------------------
# Weekly marketing digest (OPTIONAL — Resend + explicit send flag)
# -----------------------------------------------------------------------------
# RESEND_API_KEY=""
# MARKETING_DIGEST_FROM="Carasta <digest@your-verified-domain.com>"
# Must be literal "true" for real sends (CLI `npm run marketing:send-digest` and hosted job).
# MARKETING_DIGEST_SEND_ENABLED="true"

# Hosted cron: GET|POST /api/jobs/marketing-digest — Bearer or ?secret= (min 16 chars).
# MARKETING_DIGEST_CRON_SECRET=""

# CLI only: skip ~6.5-day spacing when sending digests manually (`MARKETING_DIGEST_FORCE=1`).
# MARKETING_DIGEST_FORCE="1"

# -----------------------------------------------------------------------------
# Real-time (OPTIONAL — Pusher)
# -----------------------------------------------------------------------------
# Server: all of PUSHER_APP_ID, PUSHER_KEY, PUSHER_SECRET required for broadcasts.
# Client: NEXT_PUBLIC_PUSHER_KEY required for live UI subscription (see auction detail + activity feed).
# PUSHER_APP_ID=""
# PUSHER_KEY=""
# PUSHER_SECRET=""
# PUSHER_CLUSTER="us2"
# NEXT_PUBLIC_PUSHER_KEY=""
# NEXT_PUBLIC_PUSHER_CLUSTER="us2"

# -----------------------------------------------------------------------------
# Carmunity media uploads (OPTIONAL)
# -----------------------------------------------------------------------------
# Canonical public base for returned `imageUrl` from POST /api/carmunity/media/upload
# (no trailing slash). If unset, uses NEXT_PUBLIC_SITE_URL, then the request origin.
# CARMUNITY_MEDIA_PUBLIC_BASE_URL="https://your-production-domain.com"

# -----------------------------------------------------------------------------
# Traffic event pruning script (OPTIONAL — `npm run marketing:prune-traffic-events`)
# -----------------------------------------------------------------------------
# TRAFFIC_EVENT_RETENTION_DAYS="365"
# TRAFFIC_EVENT_PRUNE_DRY_RUN="true"
# TRAFFIC_EVENT_PRUNE_ENABLED="true"

# -----------------------------------------------------------------------------
# Platform-provided (do not set manually unless you know why)
# -----------------------------------------------------------------------------
# NODE_ENV       — "development" | "production" (set by Node / hosting)
# VERCEL_URL     — hostname only, set on Vercel; used as site-origin fallback

# -----------------------------------------------------------------------------
# Build / hosting (OPTIONAL — often set in Railway Variables, not in .env)
# -----------------------------------------------------------------------------
# NIXPACKS_NODE_VERSION=20   — aligns Nixpacks Node with package.json "engines"

# -----------------------------------------------------------------------------
# Element Feedback Kit + agent shim (OPTIONAL)
# -----------------------------------------------------------------------------
# Single-tenant org id stored on every `feedback` / `agent_runs` row until real orgs exist.
# CARASTA_FEEDBACK_ORG_ID="carasta"
#
# Claude Code routine — POST /v1/claude_code/routines/{id}/fire (per-routine Bearer token from claude.ai/code/routines → API trigger).
# Use EITHER the full URL from the modal OR routine id (value includes trig_ prefix).
# CLAUDE_CODE_ROUTINE_FIRE_URL="https://api.anthropic.com/v1/claude_code/routines/trig_XXXX/fire"
# CLAUDE_CODE_ROUTINE_ID="trig_XXXX"
# CLAUDE_CODE_ROUTINE_TOKEN="sk-ant-oat01-…"   # shown once when generated; not the Console x-api-key
#
# Shared secret for POST/PATCH callbacks into `/api/agent/run/*` from an external agent.
# AGENT_SHIM_SECRET=""
#
# Local script `scripts/run-feedback-agent.mjs` (optional) may also read:
# ANTHROPIC_API_KEY=""
# GITHUB_TOKEN=""

# -----------------------------------------------------------------------------
# Not used by current in-repo routes (dependency may exist for future use)
# -----------------------------------------------------------------------------
# UploadThing env vars are not referenced under app/ or lib/; add only if you wire UploadThing.
